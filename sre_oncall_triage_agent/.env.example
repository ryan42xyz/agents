# SRE Oncall Triage Agent — Environment Configuration
# Copy to .env and fill in your values.
# .env is gitignored; .env.example is tracked as a template.

# VictoriaMetrics endpoint (used by vm_lookup.py)
VM_BASE_URL=https://victoriametrics.example.com

# Grafana endpoint (used for link generation in debug trees and output)
GRAFANA_URL=https://grafana.example.com

# Internal logging/management portal
MGT_PORTAL_URL=https://eng-mgt.example.com

# ClickHouse backfill target server
CH_BACKFILL_HOST=root@10.0.0.1

# Loki endpoint (used by loki_fetch.py)
LOKI_URL=https://loki.example.com

# Dcluster API base (used in spark job debug tree)
DCLUSTER_API_BASE=http://dcluster-{cluster}-prod.example.com
