# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Model configuration
TRIAGE_MODEL=claude-sonnet-4-20250514
TRIAGE_MAX_TOKENS=4096
TRIAGE_MAX_TURNS=20

# Tool backend: "http" (default) or "mcp"
TOOL_BACKEND=http

# VictoriaMetrics (HTTP backend)
VM_BASE_URL=https://victoriametrics.example.com

# Loki (HTTP backend)
LOKI_URL=https://loki.example.com
LOKI_ORG_ID=prod

# Knowledge base path (relative to project root)
KNOWLEDGE_BASE_PATH=../sre_oncall_triage_agent/knowledge
FACETS_PATH=../sre_oncall_triage_agent/FACETS

# Output
OUTPUT_DIR=output
TRACE_DIR=output/traces
